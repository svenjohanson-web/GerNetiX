# Einmal pro Entwicklungsrechner nach .env.staging.local kopieren.
GERNETIX_STAGING_SSH=gernetix-vps
GERNETIX_STAGING_DIR=/opt/gernetix
GERNETIX_STAGING_ENV_FILE=.env.vps
GERNETIX_STAGING_WAIT_TIMEOUT=180
GERNETIX_PRIVATE_PWA_URL=https://pwa.gernetix.com/app/dashboard/
GERNETIX_STAGING_LOCAL_ADMIN_PORT=14600
GERNETIX_STAGING_REMOTE_ADMIN_PORT=4600
GERNETIX_STAGING_LOCAL_PLATFORM_PORT=14300
GERNETIX_STAGING_REMOTE_PLATFORM_PORT=8080

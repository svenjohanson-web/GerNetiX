GERNETIX_IMAGE_TAG=local
HTTP_BIND_ADDRESS=127.0.0.1
HTTP_PORT=8080
HTTPS_BIND_ADDRESS=0.0.0.0
HTTPS_PORT=443
LETSENCRYPT_DIR=/etc/letsencrypt
ADMIN_PORT=4600
MQTT_TLS_BIND_ADDRESS=0.0.0.0
MQTT_TLS_PORT=8883
MQTT_LETSENCRYPT_DIR=/etc/letsencrypt
DEVICE_CA_CERTIFICATE_PATH=/etc/gernetix/pki/device-ca.pem
DEVICE_CA_PRIVATE_KEY_PATH=/etc/gernetix/pki/device-ca-key.pem
OTA_SIGNING_PRIVATE_KEY_PATH=/etc/gernetix/pki/ota-signing-key.pem
OTA_SIGNING_PUBLIC_KEY_PATH=/etc/gernetix/pki/ota-signing-public.pem
OTA_SIGNING_KEY_ID=ota-p256-2026-01

# Optional: externer oder auf dem VPS erreichbarer Ollama-Endpunkt.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# E-Mail-Links und interne Admin-zu-Identity-Absicherung. Eigene, lange Zufallswerte einsetzen.
IDENTITY_APP_BASE_URL=https://deine-plattform-domain.example
IDENTITY_ADMIN_TOKEN=replace-with-a-long-random-secret
EMAIL_CONFIG_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
SECURITY_MONITOR_TOKEN=replace-with-a-separate-long-random-secret
PUBLIC_DEMO_PUBLISHER_TOKEN=replace-with-a-separate-long-random-secret
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
AI_CONTEXT_POSTGRES_PASSWORD=change-me-before-deploy
AI_CONTEXT_EMBEDDING_MODEL=embeddinggemma
AI_CONTEXT_EMBEDDING_DIMENSIONS=768

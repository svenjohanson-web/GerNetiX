<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.gernetix.serial-service</string>
    <key>ProgramArguments</key>
    <array>
      <string>/Applications/GerNetiX Serial Service.app/Contents/MacOS/GerNetiX Serial Service</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
      <key>SuccessfulExit</key>
      <false/>
    </dict>
    <key>ProcessType</key>
    <string>Background</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>GERNETIX_SERIAL_TLS_PKCS12</key>
      <string>/Library/Application Support/GerNetiX Serial Service/localhost-identity.p12</string>
      <key>GERNETIX_SERIAL_TLS_PKCS12_PASSWORD_FILE</key>
      <string>/Library/Application Support/GerNetiX Serial Service/localhost-identity.password</string>
    </dict>
  </dict>
</plist>
